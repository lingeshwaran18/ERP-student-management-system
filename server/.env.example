# Port Configuration
PORT=5000
NODE_ENV=development

# Database Connection
# PostgreSQL Configuration (Default):
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/erp_db?schema=public"

# SQLite Configuration (Alternative for instant testing without a local PostgreSQL server):
# To use SQLite, change "provider" to "sqlite" in server/prisma/schema.prisma and uncomment the line below:
# DATABASE_URL="file:./dev.db"

# JWT Authentication Configuration
JWT_SECRET="your-secret-key-here-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Storage & Email Configuration
CLOUDINARY_URL="cloudinary://your-api-key"
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
FROM_EMAIL="noreply@erp-institution.edu"
